# Apple Notes export — personal paths and identity
# Copy to .env and fill in. .env is gitignored.

# Where exported markdown vault is written (Obsidian-compatible).
# Each folder under Apple Notes becomes a subdirectory here.
VAULT_PATH=~/notes-vault

# Where the flat JSON manifest is written (programmatic consumers).
EXPORT_PATH=~/notes-export

# Apple Notes SQLite database. Default is the standard macOS path.
NOTES_DB=~/Library/Group Containers/group.com.apple.notes/NoteStore.sqlite

# Your iCloud account UUID. Find it with:
#   ls ~/Library/Group\ Containers/group.com.apple.notes/Accounts/
# It's the only directory in there (or the one matching your iCloud account).
NOTES_ACCOUNT_ID=YOUR-ACCOUNT-UUID-HERE

# Whisper model size for audio transcription.
# Options: tiny | base | small | medium | large
WHISPER_MODEL=base

# Watch daemon sync interval in seconds.
WATCH_INTERVAL=300
