# iMessage export — personal paths and identity
# Copy to .env and fill in. .env is gitignored.

# Where exported markdown files are written.
# Each contact gets a subdirectory; cross-contact index lives at the root.
OUTPUT_PATH=~/work/apple/exported/imessage

# How you appear in conversation transcripts (your messages).
MY_NAME=Me

# iMessage database location. Default is the standard macOS path.
# Override only if running against a copied/backup database.
CHAT_DB=~/Library/Messages/chat.db
