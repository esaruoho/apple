#!/usr/bin/env bash
# apple-bootstrap — one-command setup for any Apple user.
#
# Usage:
#   ./bin/apple-bootstrap            # full setup + first read-only run
#   ./bin/apple-bootstrap --check    # just validate the install (no runs)
#   ./bin/apple-bootstrap --quick    # skip the slow exporters (mail/photos/music)
#
# This is the entry point for someone cloning the apple repo. It:
#   1. Verifies macOS + Python + ripgrep availability.
#   2. Copies every <name>-exporter/.env.example to .env (skips existing).
#   3. Reminds about Full Disk Access.
#   4. Runs bin/app-plist-probe.py to survey what's mineable.
#   5. Runs every read-only exporter via bin/apple-grand-export.
#   6. Opens INDEX.md.
#
# Apple-native only: bash + python3 + plistlib + ripgrep (Homebrew, optional)
# + osascript. No pip, no third-party SaaS.

set -uo pipefail

ROOT="${APPLE_REPO:-$HOME/work/apple}"
EXPORTED="$ROOT/exported"

CHECK_ONLY=0
QUICK=0
while [ $# -gt 0 ]; do
    case "$1" in
        --check) CHECK_ONLY=1; shift;;
        --quick) QUICK=1; shift;;
        -h|--help)
            head -20 "$0" | grep '^#' | sed 's|^# \?||'
            exit 0;;
        *) echo "unknown: $1" >&2; exit 2;;
    esac
done

cd "$ROOT" || { echo "apple repo not at $ROOT" >&2; exit 1; }

echo "═══════════════════════════════════════════════════════"
echo "  apple — bootstrapping at $ROOT"
echo "═══════════════════════════════════════════════════════"
echo

# 1. environment checks
echo "→ checking environment"
sw_vers -productVersion | sed 's/^/    macOS:  /'
python3 --version 2>&1 | sed 's/^/    Python: /'
if command -v rg >/dev/null 2>&1; then
    rg --version 2>&1 | head -1 | sed 's/^/    rg:     /'
else
    echo "    rg:     (not installed; apple-grand-search will fall back to grep -r)"
fi
echo "    swift:  $(/usr/bin/swift -version 2>&1 | head -1)"
echo

# 2. copy .env.example → .env for every -exporter
echo "→ ensuring .env files exist"
for d in "$ROOT"/*-exporter; do
    if [ -f "$d/.env.example" ] && [ ! -f "$d/.env" ]; then
        cp "$d/.env.example" "$d/.env"
        echo "    created  $(basename "$d")/.env"
    fi
done
echo

# 3. Full Disk Access reminder
echo "→ Full Disk Access"
echo "    Some exporters (mail, photos, voice-memos, calendar, safari)"
echo "    need Full Disk Access. If you haven't already:"
echo "      System Settings → Privacy & Security → Full Disk Access"
echo "      → add Terminal.app (or your shell host)."
echo

if [ $CHECK_ONLY -eq 1 ]; then
    echo "(--check passed; not running exporters)"
    exit 0
fi

# 4. plist probe — finds what's mineable on this Mac
echo "→ surveying every Apple app's plist data"
"$ROOT/bin/app-plist-probe.py" --md --interesting-only \
    > "$ROOT/dictionaries/all-apps-plist-survey.md" 2>/dev/null \
    && echo "    wrote $ROOT/dictionaries/all-apps-plist-survey.md" \
    || echo "    (skipped — see error)"
echo

# 5. run every read-only exporter
echo "→ running every read-only exporter"
if [ $QUICK -eq 1 ]; then
    "$ROOT/bin/apple-grand-export" --quick
else
    "$ROOT/bin/apple-grand-export"
fi
echo

# 6. write a top-level INDEX.md and open it
INDEX="$EXPORTED/INDEX.md"
mkdir -p "$EXPORTED"
{
    echo "# Apple Vault"
    echo
    echo "Generated by \`apple-bootstrap\` at $(date -Iseconds)."
    echo "Each subfolder is the output of one \`<name>-exporter\` package."
    echo
    for d in "$EXPORTED"/*; do
        [ -d "$d" ] || continue
        name=$(basename "$d")
        n_md=$(find "$d" -type f -name '*.md' 2>/dev/null | wc -l | tr -d ' ')
        size=$(du -sh "$d" 2>/dev/null | cut -f1)
        echo "- [$name](./$name) — $n_md md files, $size"
    done
} > "$INDEX"
echo "→ wrote $INDEX"
echo
open "$INDEX" 2>/dev/null || true

echo "═══════════════════════════════════════════════════════"
echo "  ready. try:"
echo "    bin/apple-grand-search 'your name'"
echo "    bin/hey-sal 'what's on my calendar today'"
echo "    bin/apple-grand-export --quick     # refresh anytime"
echo "═══════════════════════════════════════════════════════"
