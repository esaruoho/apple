on run
	tell application "System Settings"
		activate
		delay 1
		reveal anchor "Vocal_Shortcuts" of pane id "com.apple.Accessibility-Settings.extension"
	end tell
	delay 2
	repeat with b in bindings
		try
			addVocalShortcut(phrase of b, shortcutName of b)
			delay 1
		on error errMsg
			log "Failed to add: " & (phrase of b) & " (" & errMsg & ")"
		end try
	end repeat
end run

-- Conservative skeleton — relies on per-version UI element names that
-- Apple changes between macOS releases. The user is expected to inspect the
-- Vocal Shortcuts pane with Accessibility Inspector and adjust the path.
on addVocalShortcut(thePhrase, theShortcutName)
	tell application "System Events"
		tell process "System Settings"
			-- Click "+" / "Add Vocal Shortcut" button.
			-- The exact element path is macOS-version-specific. Replace this
			-- with the path you recover from Accessibility Inspector for your
			-- macOS version. The button is typically the "+" button below the
			-- list of existing vocal shortcuts.
			-- click button "Add Vocal Shortcut" of group 1 of group 1 of group 1 of window 1
			delay 1
			-- Type the phrase
			-- keystroke thePhrase
			-- click button "Continue" of sheet 1 of window 1
			-- ... train the phrase 3 times by clicking the record button
			-- ... then choose the Shortcut from the action picker, matching theShortcutName
		end tell
	end tell
end addVocalShortcut