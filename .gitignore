# ─── Private (local-only, not pushed) ───
# Personal bash profile extract — contains Ray-specific aliases and paths
bash-aliases.md

# Generated whiteboards — large PNGs, personal learning material
whiteboards/

# macOS junk
.DS_Store
**/.DS_Store

# Extracted app icons — regenerable via bin/extract-icons.sh
icons/

# Raw sdef XML (large, regenerable via bin/sdef-extract.py)
dictionaries/**/*.sdef.xml
shortcuts/

# GitHub Watcher — private runtime data
github-watcher/.state/
github-watcher/logs/
github-watcher/repos.json

# Python cache
__pycache__/
bin/__pycache__/
**/__pycache__/

# imessage-export — personal config and runtime state
imessage-export/.env
imessage-export/config.json
imessage-export/scripts/.export-state.json
imessage-export/scripts/.url-metadata-cache.json

# notes-export — personal config and runtime state
notes-export/.env
notes-export/config.json
notes-export/scripts/.export-state.json
notes-export/scripts/.transcribe-state.json
notes-export/scripts/.sync.log

# Archived media retained locally for later viewing/transcription
sources/sal/**/*.mp4
sources/sal/**/*.m4v
sources/sal/**/*.mov
sources/sal/**/*.mp3
sources/sal/**/*.m4a
sources/sal/**/*.part

# Oversized archive bundles retained locally to avoid GitHub's 100 MB file limit
sources/sal/macosxautomation.com/downloads/workshops/podcast/AUTOWKSHP-03-Leader.zip
sources/sal/macosxautomation.com/downloads/workshops/epub/EPUB-Demo-Kit-Lg.zip
sources/sal/dictationcommands.com/downloads/movies-from-dictations-comannds.zip

# CitrusPeel extracted tree (regenerable from CitrusPeel255.zip)
scripts/sal/dictation-commands/citruspeel-extracted/

# ─── Local export vaults — generated by the export packages ───
# Each user runs `<package>-export export` to populate their own vault.
# Vault content stays local; only the README lands in git.
exported/*
!exported/README.md
